# ── DATABASE ──────────────────────────────────
DATABASE_URL="postgresql://tbc_user:tbc_pass_123@localhost:5432/tbc_db"

# ── JWT ───────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ── SERVER ────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ── FILE UPLOAD ───────────────────────────────
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=5242880
